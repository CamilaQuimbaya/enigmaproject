---
import '../styles/global.css';

interface Props { title?: string; description?: string; image?: string; }
const {
  title = 'Enigma Enterprises LLC · Private Capital & Business Solutions',
  description = 'A financial consulting and referral firm connecting entrepreneurs and business owners with private capital and licensed lenders — funding, credit, real estate and business solutions.',
  image = '/enigma-logo-redgold.png',
} = Astro.props;
const site = Astro.site ?? new URL('https://enigmaenterprisesllc.org');
const canonical = new URL(Astro.url.pathname, site).href;
const ogImage = new URL(image, site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FinancialService',
  name: 'Enigma Enterprises LLC',
  description,
  url: site.href,
  logo: ogImage,
  image: ogImage,
  telephone: '+1-413-455-0488',
  email: 'Felix@EnigmaEnterprisesLLC.com',
  slogan: 'Private Capital & Business Solutions',
  areaServed: 'US',
  address: { '@type': 'PostalAddress', addressLocality: 'Springfield', addressRegion: 'MA', addressCountry: 'US' },
  sameAs: [
    'https://www.instagram.com/enigmaenterprisesllc/',
    'https://www.facebook.com/EnigmaEnterprises1/',
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <!-- Marca que hay JS lo antes posible: si el JS falla, las secciones se muestran igual -->
    <script is:inline>document.documentElement.classList.add('js')</script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="business funding, private capital, credit repair, business credit, real estate financing, hard money loans, merchant cash advance, Enigma Enterprises" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#0A0D12" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Enigma Enterprises LLC" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/png" href="/enigma-logo-redgold.png" />
    <link rel="apple-touch-icon" href="/enigma-logo-redgold.png" />
    <link rel="sitemap" href="/sitemap.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="image" fetchpriority="high" href="/img/1486406146926-c627a92ad1ab.jpg" />
    <link
      href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,500;0,6..96,600;1,6..96,500;1,6..96,600&family=Manrope:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <!-- Fondo decorativo global (malla de puntos + auroras doradas) -->
    <div class="bg-decor" aria-hidden="true"><span></span><span></span><span></span></div>

    <!-- Barra de progreso de scroll (CSS scroll-driven, nativo) -->
    <div class="scroll-progress" aria-hidden="true"></div>

    <slot />

    <!-- Textura de grano (luxury film grain) -->
    <div class="grain" aria-hidden="true"></div>

    <!-- WhatsApp flotante (glass vino + expande al hover) -->
    <a class="wa-fab" href="https://wa.me/14134550488" target="_blank" rel="noopener" aria-label="Chat on WhatsApp" data-magnetic>
      <span class="wa-label">Chat on WhatsApp</span>
      <span class="wa-ico">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.515 5.26l-.999 3.648 3.973-1.039zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413z"/></svg>
      </span>
    </a>

    <!-- Volver arriba -->
    <button class="to-top" data-to-top aria-label="Volver arriba" data-magnetic>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
    </button>

    <script>
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // ---- Botón volver arriba ----
      const toTop = document.querySelector('[data-to-top]') as HTMLElement | null;
      const onTop = () => { if (toTop) toTop.classList.toggle('show', window.scrollY > 620); };
      onTop();
      window.addEventListener('scroll', onTop, { passive: true });
      toTop?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: reduce ? 'auto' : 'smooth' }));

      // ---- Botones magnéticos (micro-interacción) ----
      if (!reduce) {
        document.querySelectorAll('[data-magnetic]').forEach((el) => {
          const b = el as HTMLElement;
          b.addEventListener('mousemove', (ev) => {
            const e = ev as MouseEvent;
            const r = b.getBoundingClientRect();
            const x = (e.clientX - (r.left + r.width / 2)) * 0.28;
            const y = (e.clientY - (r.top + r.height / 2)) * 0.4;
            b.style.transform = `translate(${x}px, ${y}px)`;
          });
          b.addEventListener('mouseleave', () => { b.style.transform = 'translate(0,0)'; });
        });
      }
    </script>
  </body>
</html>
