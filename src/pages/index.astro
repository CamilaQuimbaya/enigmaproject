<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ---------- Intro overlay safety ----------
  setTimeout(() => { const i = document.querySelector('[data-intro]'); if (i) (i as HTMLElement).style.display = 'none'; }, 2500);

  // ---------- Scroll reveal ----------
  const revealEls = Array.from(document.querySelectorAll('[data-reveal]')) as HTMLElement[];
  const show = (el: Element) => el.classList.add('in');
  if (reduce) {
    // sin animación: mostrar todo de inmediato
    revealEls.forEach(show);
  } else {
    // Animaciones REVERSIBLES (ida y vuelta): entran al bajar, se ocultan al subir,
    // y se re-animan cada vez que la sección entra/sale de la pantalla.
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => { e.target.classList.toggle('in', e.isIntersecting); });
    }, { threshold: 0, rootMargin: '-12% 0px -12% 0px' });
    revealEls.forEach((el) => io.observe(el));
  }

  // ---------- Navbar: fondo glass oscuro con blur SOLO al hacer scroll ----------
  const nav = document.querySelector('[data-nav]') as HTMLElement | null;
  const applyNav = () => {
    if (!nav) return;
    const s = (window.scrollY || 0) > 40;
    nav.style.background = s ? 'rgba(9,12,17,0.72)' : 'transparent';
    nav.style.backdropFilter = s ? 'blur(16px) saturate(130%)' : 'none';
    (nav.style as any).webkitBackdropFilter = s ? 'blur(16px) saturate(130%)' : 'none';
    nav.style.borderBottom = s ? '1px solid rgba(206,85,103,0.18)' : '1px solid transparent';
    nav.style.boxShadow = s ? '0 14px 40px -24px rgba(0,0,0,0.9)' : 'none';
  };
  applyNav();

  // ---------- Scroll-spy: resalta el enlace de la sección visible ----------
  const navLinkEls = Array.from(document.querySelectorAll('.navlink')) as HTMLAnchorElement[];
  const spyTargets = navLinkEls
    .map((l) => document.querySelector(l.getAttribute('href') || ''))
    .filter(Boolean) as HTMLElement[];
  if (spyTargets.length) {
    const spy = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        const id = '#' + (e.target as HTMLElement).id;
        navLinkEls.forEach((l) => l.classList.toggle('active', l.getAttribute('href') === id));
      });
    }, { rootMargin: '-45% 0px -50% 0px', threshold: 0 });
    spyTargets.forEach((s) => spy.observe(s));
  }

  // ---------- Parallax (throttled con requestAnimationFrame) ----------
  const parallaxEls = Array.from(document.querySelectorAll('[data-parallax]')) as HTMLElement[];
  // Imágenes de fondo con profundidad (parallax real, funciona en todos los navegadores)
  const bgImgs = Array.from(document.querySelectorAll('.bg-section > .bg-layer > img, [data-parallax-img]')) as HTMLElement[];
  let scrollScheduled = false;
  const onScroll = () => {
    applyNav();
    if (scrollScheduled) return;
    scrollScheduled = true;
    requestAnimationFrame(() => {
      scrollScheduled = false;
      const y = window.scrollY || 0;
      for (const el of parallaxEls) {
        const f = parseFloat(el.getAttribute('data-parallax') || '0.2');
        el.style.translate = '0px ' + (y * f) + 'px';
      }
      if (!reduce) {
        const vh = window.innerHeight || 1;
        for (const img of bgImgs) {
          const host = (img.closest('section') || img.parentElement) as HTMLElement;
          if (!host) continue;
          const r = host.getBoundingClientRect();
          if (r.bottom < -200 || r.top > vh + 200) continue; // fuera de vista: saltar
          const strength = parseFloat(img.getAttribute('data-parallax-img') || '0.16');
          // progreso -1 (entrando por abajo) → 1 (saliendo por arriba)
          const progress = (r.top + r.height / 2 - vh / 2) / (vh / 2 + r.height / 2);
          const shift = -progress * vh * strength;
          img.style.transform = `translate3d(0, ${shift.toFixed(1)}px, 0)`;
        }
      }
    });
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // ---------- Hero tilt + card spotlight (rAF + solo puntero fino) ----------
  const heroSection = document.getElementById('top');
  const tiltEls = Array.from(document.querySelectorAll('[data-tilt]')) as HTMLElement[];
  const spotEls = Array.from(document.querySelectorAll('[data-spot]')) as HTMLElement[];
  const finePointer = window.matchMedia('(pointer: fine)').matches;
  if (finePointer && !reduce) {
    let lastMove: MouseEvent | null = null, moveScheduled = false;
    window.addEventListener('mousemove', (e) => {
      lastMove = e;
      if (moveScheduled) return;
      moveScheduled = true;
      requestAnimationFrame(() => {
        moveScheduled = false;
        const ev = lastMove; if (!ev) return;
        const hr = heroSection?.getBoundingClientRect();
        const inHero = !!hr && ev.clientY >= hr.top && ev.clientY <= hr.bottom
                              && ev.clientX >= hr.left && ev.clientX <= hr.right;
        for (const h of tiltEls) {
          const r = h.getBoundingClientRect(); if (!r.width) continue;
          if (!inHero) { h.style.transform = 'perspective(720px) rotateX(0deg) rotateY(0deg)'; continue; }
          const dx = (ev.clientX - (r.left + r.width / 2)) / r.width;
          const dy = (ev.clientY - (r.top + r.height / 2)) / r.height;
          h.style.transform = `perspective(720px) rotateY(${(dx * 10).toFixed(2)}deg) rotateX(${(-dy * 10).toFixed(2)}deg)`;
        }
        for (const card of spotEls) {
          const r = card.getBoundingClientRect();
          const inside = ev.clientX >= r.left && ev.clientX <= r.right && ev.clientY >= r.top && ev.clientY <= r.bottom;
          if (inside) {
            const x = (ev.clientX - r.left).toFixed(0), y = (ev.clientY - r.top).toFixed(0);
            card.style.backgroundImage = `radial-gradient(360px circle at ${x}px ${y}px, rgba(111,19,32,0.13), rgba(111,19,32,0) 62%)`;
          } else if (card.style.backgroundImage) {
            card.style.backgroundImage = 'none';
          }
        }
      });
    }, { passive: true });
  }

  // ---------- Exclusive hover bg ----------
  document.querySelectorAll('[data-ex]').forEach((el) => {
    el.addEventListener('mouseenter', () => ((el as HTMLElement).style.background = '#10151E'));
    el.addEventListener('mouseleave', () => ((el as HTMLElement).style.background = '#0B0F15'));
  });

  // ---------- Tabs ----------
  const tabBtns = Array.from(document.querySelectorAll('[data-tab-btn]')) as HTMLElement[];
  const panels = Array.from(document.querySelectorAll('[data-tab-panel]')) as HTMLElement[];
  const setTab = (idx: number) => {
    tabBtns.forEach((b, i) => {
      b.style.color = i === idx ? '#A81E2E' : '#8B919C';
      const u = b.querySelector('[data-tab-underline]') as HTMLElement;
      if (u) u.style.display = i === idx ? 'block' : 'none';
    });
    panels.forEach((p, i) => { p.style.display = i === idx ? 'grid' : 'none'; });
    if (panels[idx]) panels[idx].querySelectorAll('[data-reveal]').forEach((el) => el.classList.add('in'));
  };
  tabBtns.forEach((b, i) => b.addEventListener('click', () => setTab(i)));
  setTab(0);

  // ---------- Mobile menu (overlay glass) ----------
  let mob = false;
  const mobBtn = document.querySelector('[data-nav-toggle]') as HTMLElement | null;
  const mobMenu = document.querySelector('[data-mobile-menu]') as HTMLElement | null;
  const setMob = (open: boolean) => {
    mob = open;
    mobMenu?.classList.toggle('open', open);
    mobBtn?.classList.toggle('open', open);
    mobBtn?.setAttribute('aria-expanded', String(open));
    mobBtn?.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    document.body.style.overflow = open ? 'hidden' : '';
  };
  mobBtn?.addEventListener('click', () => setMob(!mob));
  document.querySelectorAll('[data-mobile-link]').forEach((a) =>
    a.addEventListener('click', () => setMob(false)));
  // Tocar el fondo (fuera de un enlace) cierra el menú
  mobMenu?.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    if (!t.closest('a')) setMob(false);
  });
  window.addEventListener('keydown', (e) => { if (e.key === 'Escape' && mob) setMob(false); });

  // ---------- Funding request form ----------
  const form = document.querySelector('[data-apply-form]') as HTMLFormElement;
  const thanks = document.querySelector('[data-apply-thanks]') as HTMLElement;
  const errBox = document.querySelector('[data-apply-error]') as HTMLElement | null;
  const submitBtn = document.querySelector('[data-apply-submit]') as HTMLButtonElement | null;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.reportValidity()) return;
    const payload = Object.fromEntries(new FormData(form).entries());
    if (errBox) errBox.style.display = 'none';
    if (submitBtn) { submitBtn.disabled = true; submitBtn.style.opacity = '0.7'; submitBtn.textContent = 'Sending…'; }
    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!res.ok) throw new Error('request_failed');
      form.style.display = 'none';
      if (thanks) thanks.style.display = 'flex';
      thanks?.scrollIntoView({ behavior: reduce ? 'auto' : 'smooth', block: 'center' });
    } catch {
      if (errBox) errBox.style.display = 'block';
      if (submitBtn) { submitBtn.disabled = false; submitBtn.style.opacity = '1'; submitBtn.textContent = 'Submit Funding Request for Review'; }
    }
  });
</script>
