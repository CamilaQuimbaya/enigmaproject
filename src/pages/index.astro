---
import Layout from '../layouts/Layout.astro';
import { financing, realEstate, products, exclusive } from '../data/services';

const LOGO = '/enigma-logo-redgold.png';
// 👉 REEMPLAZAR por el enlace real de Cal.com del cliente, ej: 'felix-enigma/consultation'
const CAL_LINK = 'TU_USUARIO/consultation';
const navLinks = [
  ['#services', 'Services'], ['#financing', 'Financing'],
  ['#realestate', 'Real Estate'], ['#education', 'Education'],
  ['#schedule', 'Schedule'], ['#contact', 'Contact'],
];
const points = [
  ['Consulting & Referral Model', 'We connect you to the right source of capital — no balance sheet of our own to protect.'],
  ['A Personalized Approach', 'Every introduction is tailored to your goals, your timeline, and your numbers.'],
  ['Compliance First', 'We work only with licensed lenders, and final decisions always rest with them.'],
];
const stats = [
  ['100', '$', 'M+', 'Capital Range Accessed'],
  ['500', '', '+', 'Businesses Connected'],
  ['15', '', '+', 'Years of Experience'],
  ['50', '', '', 'States Served'],
];
---

<Layout>
  <!-- ===== INTRO ===== -->
  <div data-intro aria-hidden="true" style="position:fixed;inset:0;z-index:1000;background:radial-gradient(120% 120% at 50% 44%,#11161E,#070A0E);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:24px;animation:introOut .85s ease 1.5s forwards;">
    <div style="position:relative;display:flex;align-items:center;justify-content:center;width:200px;height:200px;animation:introIn 1s cubic-bezier(.2,.7,.2,1) both;">
      <div style="position:absolute;width:200px;height:200px;border-radius:50%;background:conic-gradient(from 0deg,rgba(111,19,32,0),rgba(206,85,103,.62),rgba(111,19,32,0) 50%,rgba(111,19,32,0) 65%,rgba(206,85,103,.34),rgba(111,19,32,0) 95%);-webkit-mask:radial-gradient(closest-side,transparent 71%,#000 73%,#000 79%,transparent 81%);mask:radial-gradient(closest-side,transparent 71%,#000 73%,#000 79%,transparent 81%);animation:spin 10s linear infinite;"></div>
      <img src={LOGO} alt="" style="position:relative;width:104px;height:104px;object-fit:contain;animation:logoglow 3.5s ease-in-out infinite;" />
    </div>
    <span style="font-family:'Bodoni Moda',serif;font-weight:600;font-size:24px;letter-spacing:.44em;color:#F2EEE6;padding-left:.44em;animation:introIn 1s ease .12s both;">ENIGMA</span>
  </div>

  <!-- ===== HEADER ===== -->
  <header style="position:fixed;top:0;left:0;right:0;z-index:100;">
    <nav data-nav style="display:flex;align-items:center;justify-content:space-between;gap:24px;height:74px;padding:0 clamp(18px,4vw,48px);transition:background .45s,backdrop-filter .45s,border-color .45s,box-shadow .45s;border-bottom:1px solid transparent;">
      <a href="#top" style="display:flex;align-items:center;gap:13px;">
        <img src={LOGO} alt="Enigma Enterprises LLC logo" style="width:46px;height:46px;flex:none;object-fit:contain;" />
        <span style="display:flex;flex-direction:column;line-height:1;">
          <span style="font-family:'Bodoni Moda',serif;font-weight:600;font-size:23px;letter-spacing:.22em;color:#F2EEE6;">ENIGMA</span>
          <span style="font-size:8.5px;letter-spacing:.42em;color:#6F1320;margin-top:4px;font-weight:600;">ENTERPRISES LLC</span>
        </span>
      </a>
      <div data-desktop-nav style="display:flex;align-items:center;gap:34px;">
        {navLinks.map(([href, label]) => <a class="navlink" href={href}>{label}</a>)}
      </div>
      <div style="display:flex;align-items:center;gap:18px;">
        <a href="#contact" class="btn-gold" data-desktop-nav data-magnetic style="font-size:13px;letter-spacing:.06em;padding:12px 24px;">APPLY NOW</a>
        <button data-nav-toggle aria-label="Open menu" style="display:none;width:44px;height:44px;align-items:center;justify-content:center;background:transparent;border:1px solid rgba(111,19,32,.4);border-radius:2px;cursor:pointer;flex-direction:column;gap:5px;">
          <span style="width:20px;height:1.5px;background:#A81E2E;display:block;"></span>
          <span style="width:20px;height:1.5px;background:#A81E2E;display:block;"></span>
          <span style="width:20px;height:1.5px;background:#A81E2E;display:block;"></span>
        </button>
      </div>
    </nav>
    <div data-mobile-menu style="display:none;background:rgba(10,13,18,.97);backdrop-filter:blur(16px);border-bottom:1px solid rgba(111,19,32,.18);padding:18px clamp(18px,4vw,48px) 26px;flex-direction:column;gap:4px;">
      {navLinks.map(([href, label]) => <a href={href} data-mobile-link style="color:#E8EAEE;font-size:16px;padding:13px 0;border-bottom:1px solid rgba(255,255,255,.05);">{label}</a>)}
      <a href="#contact" data-mobile-link class="btn-gold" style="margin-top:16px;text-align:center;letter-spacing:.06em;padding:14px;">APPLY NOW</a>
    </div>
  </header>

  <!-- ===== HERO ===== -->
  <section id="top" style="position:relative;min-height:100vh;display:flex;align-items:center;overflow:hidden;padding:120px clamp(18px,4vw,48px) 90px;">
    <div style="position:absolute;inset:0;overflow:hidden;pointer-events:none;">
      <img src="/img/1486406146926-c627a92ad1ab.jpg" alt="" aria-hidden="true" fetchpriority="high" decoding="async" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.58;animation:kenburns 28s ease-in-out infinite alternate;" />
      <div style="position:absolute;inset:0;background:radial-gradient(120% 90% at 50% 40%,rgba(10,13,18,.5),rgba(10,13,18,.78)),linear-gradient(180deg,rgba(10,13,18,.55),rgba(10,13,18,.7) 70%,#0A0D12);"></div>
    </div>
    <div data-parallax="0.18" style="position:absolute;top:-12%;left:-6%;width:46vw;height:46vw;max-width:680px;max-height:680px;pointer-events:none;">
      <div style="width:100%;height:100%;border-radius:50%;background:radial-gradient(circle,rgba(111,19,32,.22),rgba(111,19,32,0) 68%);filter:blur(20px);animation:drift 16s ease-in-out infinite;"></div>
    </div>
    <div data-parallax="0.28" style="position:absolute;bottom:-18%;right:-10%;width:50vw;height:50vw;max-width:720px;max-height:720px;pointer-events:none;">
      <div style="width:100%;height:100%;border-radius:50%;background:radial-gradient(circle,rgba(224,24,24,.13),rgba(224,24,24,0) 66%);filter:blur(24px);animation:drift2 19s ease-in-out infinite;"></div>
    </div>
    <div style="position:relative;width:min(1180px,100%);margin:0 auto;display:flex;flex-direction:column;align-items:center;text-align:center;gap:30px;">
      <div data-reveal data-tilt style="position:relative;width:clamp(148px,16.5vw,186px);height:clamp(148px,16.5vw,186px);display:flex;align-items:center;justify-content:center;transform-style:preserve-3d;will-change:transform;margin-bottom:2px;">
        <div style="position:absolute;inset:8%;border-radius:50%;background:radial-gradient(circle,rgba(111,19,32,.2),rgba(111,19,32,0) 70%);filter:blur(12px);animation:ringfloat 7s ease-in-out infinite;"></div>
        <div style="position:absolute;inset:0;border-radius:50%;background:conic-gradient(from 0deg,rgba(111,19,32,0),rgba(206,85,103,.55),rgba(111,19,32,0) 45%,rgba(111,19,32,0) 60%,rgba(206,85,103,.32),rgba(111,19,32,0) 95%);-webkit-mask:radial-gradient(closest-side,transparent 80%,#000 82%,#000 85.5%,transparent 87.5%);mask:radial-gradient(closest-side,transparent 80%,#000 82%,#000 85.5%,transparent 87.5%);animation:spin 24s linear infinite;"></div>
        <img src={LOGO} alt="Enigma Enterprises LLC monogram" style="position:relative;width:48%;height:48%;object-fit:contain;animation:logoglow 5s ease-in-out infinite;" />
      </div>
      <div data-reveal style="display:inline-flex;align-items:center;gap:14px;padding:9px 20px;border:1px solid rgba(111,19,32,.34);border-radius:40px;background:rgba(111,19,32,.06);">
        <span style="width:6px;height:6px;border-radius:50%;background:#6F1320;box-shadow:0 0 10px #6F1320;"></span>
        <span style="font-size:11.5px;letter-spacing:.34em;color:#A81E2E;font-weight:600;">PRIVATE CAPITAL &amp; BUSINESS SOLUTIONS</span>
      </div>
      <h1 data-reveal style="font-family:'Bodoni Moda',serif;font-weight:600;font-size:clamp(40px,7.4vw,86px);line-height:1.04;letter-spacing:-.01em;color:#F6F2E9;max-width:16ch;">Connecting You With the Right <span style="background:linear-gradient(120deg,#A81E2E,#6F1320,#A81E2E);background-size:200% auto;-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;animation:sheen 7s ease-in-out infinite;font-style:italic;">Financial Solutions</span></h1>
      <p data-reveal style="max-width:62ch;font-size:clamp(16px,1.7vw,19px);line-height:1.7;color:#AEB4BF;font-weight:300;">We are a financial consulting and referral firm built for entrepreneurs and business owners. Through our network of private capital and licensed lenders, we open doors to the funding and strategy your next move demands.</p>
      <div data-reveal data-hero-actions style="display:flex;gap:16px;margin-top:8px;">
        <a href="#contact" class="btn-gold" data-magnetic style="font-size:14px;padding:17px 38px;">Apply Now</a>
        <a href="#contact" class="btn-outline" data-magnetic style="font-size:14px;padding:17px 38px;">Request a Consultation</a>
      </div>
    </div>
  </section>

  <!-- ===== COSTURA DORADA (hero → stats) ===== -->
  <div class="seam" aria-hidden="true"></div>

  <!-- ===== STATS (fondo inmersivo + cascada) ===== -->
  <section class="bg-section sweep" data-reveal data-stagger-parent style="border-top:1px solid rgba(111,19,32,.12);border-bottom:1px solid rgba(111,19,32,.12);padding:clamp(48px,7vw,76px) clamp(18px,4vw,48px);">
    <div class="bg-layer"><img src="/img/1554260570-9140fd3b7614.jpg" alt="" aria-hidden="true" loading="lazy" decoding="async" /></div>
    <div class="bg-veil" style="background:linear-gradient(180deg,rgba(10,13,18,.82),rgba(12,16,23,.86));"></div>
    <div style="width:min(1180px,100%);margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:24px;text-align:center;">
      {stats.map(([count, pre, suf, label], i) => (
        <div data-stagger style={`--i:${i};display:flex;flex-direction:column;gap:10px;padding:14px;${i > 0 ? 'border-left:1px solid rgba(111,19,32,.12);' : ''}`}>
          <span data-count={count} data-pre={pre} data-suf={suf} style="font-family:'Bodoni Moda',serif;font-weight:600;font-size:clamp(40px,5vw,58px);color:#A81E2E;line-height:1;">{pre}0{suf}</span>
          <span style="font-size:12px;letter-spacing:.16em;color:#969CA8;text-transform:uppercase;">{label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== MARQUEE / TRUST STRIP ===== -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      {['Private Capital', 'Credit Repair', 'Business Credit', 'Real Estate Funding', 'Merchant Services', 'Hard Money', 'Trust Education', 'Personal Funding'].concat(['Private Capital', 'Credit Repair', 'Business Credit', 'Real Estate Funding', 'Merchant Services', 'Hard Money', 'Trust Education', 'Personal Funding']).map((w) => (
        <span class="marquee-item">{w}</span>
      ))}
    </div>
  </div>

  <!-- ===== COSTURA DORADA (services) ===== -->
  <div class="seam" aria-hidden="true"></div>

  <!-- ===== WHAT WE DO ===== -->
  <section id="services" style="padding:clamp(80px,11vw,140px) clamp(18px,4vw,48px);">
    <div data-split style="width:min(1180px,100%);margin:0 auto;display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(40px,6vw,80px);align-items:center;">
      <div data-reveal="left" style="display:flex;flex-direction:column;gap:26px;">
        <span class="eyebrow">WHAT WE DO</span>
        <h2 class="h2">A consulting partner, not a lender.</h2>
        <p style="font-size:16.5px;line-height:1.75;color:#AEB4BF;font-weight:300;">Enigma Enterprises operates as a referral and advisory firm. We do not issue loans or hold deposits. Instead, we study your situation, then match you with the private capital networks and licensed lenders best positioned to say yes — with strategy and compliance guiding every introduction.</p>
        <div style="display:flex;flex-direction:column;gap:18px;margin-top:4px;">
          {points.map(([t, d], i) => (
            <div style="display:flex;gap:16px;align-items:flex-start;">
              <span style="flex:none;margin-top:3px;width:30px;height:30px;border-radius:50%;border:1px solid rgba(111,19,32,.45);display:flex;align-items:center;justify-content:center;color:#A81E2E;font-family:'Bodoni Moda',serif;font-size:15px;">{i + 1}</span>
              <div><h4 style="margin:0 0 5px;font-size:16px;color:#F0ECE3;font-weight:600;font-family:var(--font-sans);">{t}</h4><p style="margin:0;font-size:14.5px;color:#9AA0AB;line-height:1.6;font-weight:300;">{d}</p></div>
            </div>
          ))}
        </div>
      </div>
      <div data-reveal="right" style="position:relative;">
        <div style="position:absolute;inset:-1px;border-radius:4px;background:linear-gradient(135deg,rgba(111,19,32,.5),rgba(111,19,32,0) 55%);"></div>
        <div style="position:relative;height:clamp(360px,46vw,520px);border-radius:4px;overflow:hidden;">
          <img src="/img/1521791136064-7986c2920216.jpg" alt="Two business professionals shaking hands to close a financing agreement" loading="lazy" decoding="async" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;animation:kenburns 24s ease-in-out infinite alternate;" />
          <div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(10,13,18,.12),rgba(10,13,18,.62));"></div>
          <div style="position:absolute;left:24px;bottom:22px;display:flex;align-items:center;gap:11px;">
            <span style="width:7px;height:7px;border-radius:50%;background:#6F1320;box-shadow:0 0 10px #6F1320;"></span>
            <span style="font-size:12.5px;letter-spacing:.16em;color:#E8E2D4;text-transform:uppercase;font-weight:600;">Relationships that close deals</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FINANCING (TABS) — borde diagonal + fondo inmersivo ===== -->
  <section id="financing" class="bg-section clip-top sweep" style="padding:clamp(96px,12vw,150px) clamp(18px,4vw,48px) clamp(72px,9vw,120px);">
    <div class="bg-layer"><img src="/img/1620714223084-8fcacc6dfd8d.jpg" alt="" aria-hidden="true" loading="lazy" decoding="async" /></div>
    <div class="bg-veil" style="background:linear-gradient(180deg,rgba(8,11,16,.93),rgba(12,16,23,.88) 50%,rgba(8,11,16,.93));"></div>
    <div style="width:min(1180px,100%);margin:0 auto;">
      <div data-reveal style="text-align:center;display:flex;flex-direction:column;gap:16px;align-items:center;margin-bottom:46px;">
        <span class="eyebrow">FINANCING SOLUTIONS</span>
        <h2 class="h2" style="max-width:18ch;">Capital for every stage of your ambition.</h2>
        <p class="lead" style="max-width:60ch;">Explore our solutions by category. Each one connects you to vetted lenders within our network.</p>
      </div>
      <div data-tabrow style="display:flex;justify-content:center;gap:8px;margin-bottom:44px;border-bottom:1px solid rgba(111,19,32,.14);">
        {['Personal & Business', 'Real Estate', 'Products & Requirements'].map((t, i) => (
          <button data-tab-btn={i} style="position:relative;background:transparent;border:none;cursor:pointer;padding:16px 22px;font-size:14px;font-weight:600;letter-spacing:.04em;color:#8B919C;transition:color .3s;">
            {t}<span data-tab-underline style="position:absolute;left:14px;right:14px;bottom:-1px;height:2px;background:linear-gradient(90deg,#A81E2E,#6F1320);display:none;"></span>
          </button>
        ))}
      </div>

      <div data-tab-panel="0" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(270px,1fr));gap:22px;">
        {financing.map((c, i) => (
          <div class="card" data-reveal data-spot style={`transition-delay:${(i * 0.09).toFixed(2)}s`}>
            <div class="card-img"><img src={c.img} alt={c.name} loading="lazy" decoding="async" /></div>
            <div class="card-body">
              <span class="card-rule"></span>
              <h3 class="card-title">{c.name}</h3>
              <p class="card-desc">{c.desc}</p>
              <a href="#contact" class="gold-link" style="margin-top:auto;padding-top:14px;">Explore this option →</a>
            </div>
          </div>
        ))}
      </div>

      <div data-tab-panel="1" style="display:none;grid-template-columns:repeat(auto-fit,minmax(270px,1fr));gap:22px;">
        {realEstate.map((c, i) => (
          <div class="card" data-reveal data-spot style={`transition-delay:${(i * 0.09).toFixed(2)}s`}>
            <div class="card-img"><img src={c.img} alt={c.name} loading="lazy" decoding="async" /></div>
            <div class="card-body">
              <span class="card-rule"></span>
              <h3 class="card-title">{c.name}</h3>
              <p class="card-desc">{c.desc}</p>
              <a href="#contact" class="gold-link" style="margin-top:auto;padding-top:14px;">Explore this option →</a>
            </div>
          </div>
        ))}
      </div>

      <div data-tab-panel="2" style="display:none;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:22px;">
        {products.map((p, i) => (
          <div class="card" data-reveal data-spot style={`padding:32px 28px;gap:14px;transition-delay:${(i * 0.09).toFixed(2)}s`}>
            <h3 class="card-title">{p.name}</h3>
            <p class="card-desc" style="font-size:14px;">{p.desc}</p>
            <div style="display:flex;flex-direction:column;margin-top:2px;">
              {p.specs.map((s) => (
                <div style="display:flex;justify-content:space-between;align-items:baseline;gap:14px;padding:9px 0;border-top:1px solid rgba(255,255,255,.06);">
                  <span style="font-size:12px;letter-spacing:.06em;text-transform:uppercase;color:#888E99;">{s.k}</span>
                  <span style="font-size:13.5px;font-weight:600;color:#A81E2E;text-align:right;">{s.v}</span>
                </div>
              ))}
            </div>
            <a href="#contact" class="gold-link" style="margin-top:auto;padding-top:6px;">Check eligibility →</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== UK SYNDICATE ===== -->
  <section id="realestate" style="padding:clamp(72px,9vw,120px) clamp(18px,4vw,48px);">
    <div data-reveal="clip" style="width:min(1180px,100%);margin:0 auto;position:relative;border-radius:5px;overflow:hidden;border:1px solid rgba(111,19,32,.25);">
      <div style="position:absolute;inset:0;overflow:hidden;">
        <img src="/img/1480714378408-67cf0d13bc1b.jpg" alt="Aerial view of a financial-district skyline at dusk" loading="lazy" decoding="async" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;animation:kenburns2 30s ease-in-out infinite alternate;" />
      </div>
      <div style="position:absolute;inset:0;background:linear-gradient(110deg,rgba(8,11,16,.94) 32%,rgba(8,11,16,.6) 70%,rgba(8,11,16,.4)),radial-gradient(80% 120% at 110% 50%,rgba(111,19,32,.18),rgba(8,11,16,0) 60%);"></div>
      <div style="position:relative;padding:clamp(44px,6vw,80px) clamp(28px,5vw,72px);display:flex;flex-direction:column;gap:20px;max-width:680px;">
        <span style="font-size:11px;letter-spacing:.34em;color:#A81E2E;font-weight:600;">FLAGSHIP PROGRAM</span>
        <h2 style="font-family:'Bodoni Moda',serif;font-weight:600;font-size:clamp(34px,5vw,60px);line-height:1.05;color:#F8F4EB;">UK Base Syndicate Program</h2>
        <div style="display:flex;align-items:baseline;gap:14px;flex-wrap:wrap;">
          <span style="font-family:'Bodoni Moda',serif;font-size:clamp(30px,4vw,46px);font-weight:600;color:#A81E2E;">$3M – $100M</span>
          <span style="font-size:13px;letter-spacing:.1em;color:#AEB4BF;text-transform:uppercase;">institutional capital syndication</span>
        </div>
        <p style="font-size:16px;line-height:1.7;color:#C4C9D1;font-weight:300;max-width:54ch;">Our most exclusive offering — structured syndicated capital for large-scale acquisitions, development, and commercial real estate ventures, sourced through an international network of private investors and institutions.</p>
        <a href="#contact" class="btn-gold" style="align-self:flex-start;margin-top:6px;font-size:13.5px;padding:15px 34px;">Inquire About Syndication</a>
      </div>
    </div>
  </section>

  <!-- ===== COSTURA DORADA (exclusive) ===== -->
  <div class="seam" aria-hidden="true"></div>

  <!-- ===== EXCLUSIVE — fondo inmersivo ===== -->
  <section class="bg-section" style="padding:clamp(56px,7vw,90px) clamp(18px,4vw,48px) clamp(72px,9vw,120px);">
    <div class="bg-layer"><img src="/img/1507679799987-c73779587ccf.jpg" alt="" aria-hidden="true" loading="lazy" decoding="async" /></div>
    <div class="bg-veil" style="background:linear-gradient(180deg,rgba(10,13,18,.9),rgba(8,11,16,.92));"></div>
    <div style="width:min(1180px,100%);margin:0 auto;">
      <div data-reveal style="display:flex;flex-direction:column;gap:14px;margin-bottom:42px;">
        <span class="eyebrow">EXCLUSIVE SERVICES</span>
        <h2 class="h2">Beyond funding — building the foundation.</h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:1px;background:rgba(111,19,32,.14);border:1px solid rgba(111,19,32,.14);border-radius:3px;overflow:hidden;">
        {exclusive.map((c, i) => (
          <div data-reveal="flip" data-ex style={`background:#0B0F15;padding:36px 30px;display:flex;flex-direction:column;gap:12px;min-height:200px;transition-delay:${(i * 0.08).toFixed(2)}s;`}>
            <span style="font-family:'Bodoni Moda',serif;font-size:20px;color:#6F1320;">0{c.n}</span>
            <h3 style="font-family:'Bodoni Moda',serif;font-weight:600;font-size:22px;color:#F2EEE6;line-height:1.15;">{c.name}</h3>
            <p style="margin:0;font-size:14px;line-height:1.6;color:#9AA0AB;font-weight:300;">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== MERCHANT SERVICES — bordes diagonales + fondo ===== -->
  <section class="bg-section clip-both sweep" style="padding:clamp(92px,11vw,128px) clamp(18px,4vw,48px);">
    <div class="bg-layer"><img src="/img/1556742502-ec7c0e9f34b1.jpg" alt="" aria-hidden="true" loading="lazy" decoding="async" /></div>
