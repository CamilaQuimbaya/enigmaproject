<script is:inline define:vars={{ CAL_LINK }}>
  (function () {
    const el = document.getElementById('cal-inline');
    const fallback = document.querySelector('[data-cal-fallback]');
    const ready = String(CAL_LINK || '').length > 0 && !String(CAL_LINK).includes('TU_USUARIO');
    if (!ready) {
      if (el) el.style.display = 'none';
      if (fallback) fallback.style.display = 'flex';
