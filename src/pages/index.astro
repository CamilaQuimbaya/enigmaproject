---
import Layout from '../layouts/Layout.astro';
import { financing, realEstate, products } from '../data/services';

const LOGO = '/enigma-logo-redgold.png';
// Números de confianza (valores FIJOS y reales — nunca "0"). Ajustar a las cifras reales de Felix.
const stats = [
  ['$100M+', 'Capital Range Accessed'],
  ['500+', 'Businesses Connected'],
  ['15+', 'Years of Experience'],
  ['50', 'States Served'],
];
const navLinks = [
  ['#services', 'Services'], ['#about', 'About'],
  ['#faq', 'FAQ'], ['#apply', 'Apply'],
];
const points = [
  ['Consulting & Referral Model', 'We connect you to the right source of capital — no balance sheet of our own to protect.'],
  ['A Personalized Approach', 'Every introduction is tailored to your goals, your timeline, and your numbers.'],
  ['Compliance First', 'We work only with licensed lenders, and final decisions always rest with them.'],
];
// Opciones del formulario de solicitud (punto 5)
const financingTypes = ['Business Financing', 'Real Estate Financing', 'Private Capital / Large Deal', 'Business Credit', 'Merchant Services', 'Personal Financing', 'Other'];
const creditRanges = ['Excellent (720+)', 'Good (680–719)', 'Fair (620–679)', 'Poor (below 620)', 'Not sure'];
const timeOptions = ['Startup (under 1 year)', '1–2 years', '3–5 years', '5+ years'];
const roleOptions = ['Business Owner', 'Broker / Referral Partner', 'Representative'];
const steps = [
  ['01', 'Apply', 'Share your goals, timeline and numbers in a short, no-obligation application — it takes just minutes.'],
  ['02', 'Get Matched', 'We study your situation and connect you with the licensed lenders and private capital networks best positioned to say yes.'],
  ['03', 'Get Funded', 'Review terms directly with the lender, choose what works for you, and move your next project forward.'],
];
const audiences = [
  ['Entrepreneurs & Startups', 'Early-stage founders seeking their first capital to launch, build, and grow.'],
  ['Established Businesses', 'Owners funding expansion, equipment, inventory, payroll or new locations.'],
  ['Real Estate Investors', 'Buyers and developers financing commercial and residential deals.'],
  ['Individuals & Families', 'People pursuing a first home, education, or personal financial goals.'],
];
const faqs = [
  ['Are you a bank or a lender?', 'No. Enigma Enterprises is a consulting and referral firm. We connect you with licensed lenders and private capital networks — all funding decisions rest solely with them.'],
  ['Does requesting a consultation affect my credit?', 'No. Sharing your information for a consultation does not impact your credit. Any formal credit check is performed only by the lender, with your consent.'],
  ['How much does it cost to get matched?', 'The initial consultation and matching process is completely free and carries no obligation.'],
  ['How fast can I get funded?', 'Timelines vary by program and lender, but many clients receive options within a few business days of applying.'],
  ['What types of funding do you cover?', 'Personal and business funding, business credit, real estate financing, merchant services, and our flagship UK Base Syndicate program.'],
];
---

<Layout>
  <!-- ===== INTRO ===== -->
  <div data-intro aria-hidden="true" style="position:fixed;inset:0;z-index:1000;background:radial-gradient(120% 120% at 50% 44%,#11161E,#070A0E);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:24px;animation:introOut .85s ease 1.5s forwards;">
    <div style="position:relative;display:flex;align-items:center;justify-content:center;width:200px;height:200px;animation:introIn 1s cubic-bezier(.2,.7,.2,1) both;">
      <div style="position:absolute;width:200px;height:200px;border-radius:50%;background:conic-gradient(from 0deg,rgba(111,19,32,0),rgba(206,85,103,.62),rgba(111,19,32,0) 50%,rgba(111,19,32,0) 65%,rgba(206,85,103,.34),rgba(111,19,32,0) 95%);-webkit-mask:radial-gradient(closest-side,transparent 71%,#000 73%,#000 79%,transparent 81%);mask:radial-gradient(closest-side,transparent 71%,#000 73%,#000 79%,transparent 81%);animation:spin 10s linear infinite;"></div>
      <img src={LOGO} alt="" style="position:relative;width:104px;height:104px;object-fit:contain;animation:logoglow 3.5s ease-in-out infinite;" />
    </div>
    <span style="font-family:'Bodoni Moda',serif;font-weight:600;font-size:24px;letter-spacing:.44em;color:#F2EEE6;padding-left:.44em;animation:introIn 1s ease .12s both;">ENIGMA</span>
  </div>

  <!-- ===== HEADER (barra clásica, glass al hacer scroll) ===== -->
  <header style="position:fixed;top:0;left:0;right:0;z-index:100;">
    <nav data-nav style="display:flex;align-items:center;justify-content:space-between;gap:24px;height:74px;padding:0 clamp(18px,4vw,48px);transition:background .5s ease,backdrop-filter .5s ease,border-color .5s ease,box-shadow .5s ease;border-bottom:1px solid transparent;">
      <a href="#top" style="display:flex;align-items:center;gap:13px;">
        <img src={LOGO} alt="Enigma Enterprises LLC logo" style="width:46px;height:46px;flex:none;object-fit:contain;" />
        <span style="display:flex;flex-direction:column;line-height:1;">
          <span style="font-family:'Bodoni Moda',serif;font-weight:600;font-size:23px;letter-spacing:.22em;color:#F2EEE6;">ENIGMA</span>
          <span style="font-size:8.5px;letter-spacing:.42em;color:var(--gold-3);margin-top:4px;font-weight:600;">ENTERPRISES LLC</span>
        </span>
      </a>
      <div data-desktop-nav style="display:flex;align-items:center;gap:34px;">
        {navLinks.map(([href, label]) => <a class="navlink" href={href}>{label}</a>)}
      </div>
      <div style="display:flex;align-items:center;gap:18px;">
        <a href="#apply" class="btn-gold" data-desktop-nav data-magnetic style="font-size:13px;letter-spacing:.06em;padding:12px 24px;">APPLY NOW</a>
        <button data-nav-toggle class="nav-toggle" aria-label="Open menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </nav>
    <div data-mobile-menu class="mobile-menu">
      <div class="mobile-menu-inner">
        {navLinks.map(([href, label], i) => (
          <a href={href} data-mobile-link class="mobile-link" style={`--i:${i}`}>
            <span class="mobile-link-idx">0{i + 1}</span><span>{label}</span>
          </a>
        ))}
        <a href="#apply" data-mobile-link class="btn-gold mobile-cta" style="--i:4">Submit a Funding Request</a>
      </div>
    </div>
  </header>

  <!-- ===== HERO ===== -->
  <section id="top" style="position:relative;min-height:100vh;display:flex;align-items:center;overflow:hidden;padding:120px clamp(18px,4vw,48px) 90px;">
    <div style="position:absolute;inset:0;overflow:hidden;pointer-events:none;">
      <img src="/img/1486406146926-c627a92ad1ab.jpg" alt="" aria-hidden="true" fetchpriority="high" decoding="async" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.58;animation:kenburns 28s ease-in-out infinite alternate;" />
      <div style="position:absolute;inset:0;background:radial-gradient(120% 90% at 50% 40%,rgba(10,13,18,.5),rgba(10,13,18,.78)),linear-gradient(180deg,rgba(10,13,18,.55),rgba(10,13,18,.7) 70%,#0A0D12);"></div>
    </div>
    <div data-parallax="0.18" style="position:absolute;top:-12%;left:-6%;width:46vw;height:46vw;max-width:680px;max-height:680px;pointer-events:none;">
      <div style="width:100%;height:100%;border-radius:50%;background:radial-gradient(circle,rgba(111,19,32,.22),rgba(111,19,32,0) 68%);filter:blur(20px);animation:drift 16s ease-in-out infinite;"></div>
    </div>
    <div data-parallax="0.28" style="position:absolute;bottom:-18%;right:-10%;width:50vw;height:50vw;max-width:720px;max-height:720px;pointer-events:none;">
      <div style="width:100%;height:100%;border-radius:50%;background:radial-gradient(circle,rgba(224,24,24,.13),rgba(224,24,24,0) 66%);filter:blur(24px);animation:drift2 19s ease-in-out infinite;"></div>
    </div>
    <div style="position:relative;width:min(1180px,100%);margin:0 auto;display:flex;flex-direction:column;align-items:center;text-align:center;gap:30px;">
      <div data-reveal data-tilt style="position:relative;width:clamp(148px,16.5vw,186px);height:clamp(148px,16.5vw,186px);display:flex;align-items:center;justify-content:center;transform-style:preserve-3d;will-change:transform;margin-bottom:2px;">
        <div style="position:absolute;inset:8%;border-radius:50%;background:radial-gradient(circle,rgba(111,19,32,.2),rgba(111,19,32,0) 70%);filter:blur(12px);animation:ringfloat 7s ease-in-out infinite;"></div>
        <div style="position:absolute;inset:0;border-radius:50%;background:conic-gradient(from 0deg,rgba(111,19,32,0),rgba(206,85,103,.55),rgba(111,19,32,0) 45%,rgba(111,19,32,0) 60%,rgba(206,85,103,.32),rgba(111,19,32,0) 95%);-webkit-mask:radial-gradient(closest-side,transparent 80%,#000 82%,#000 85.5%,transparent 87.5%);mask:radial-gradient(closest-side,transparent 80%,#000 82%,#000 85.5%,transparent 87.5%);animation:spin 24s linear infinite;"></div>
        <img src={LOGO} alt="Enigma Enterprises LLC monogram" style="position:relative;width:48%;height:48%;object-fit:contain;animation:logoglow 5s ease-in-out infinite;" />
      </div>
      <div data-reveal style="display:inline-flex;align-items:center;gap:14px;padding:9px 20px;border:1px solid rgba(111,19,32,.34);border-radius:2px;background:rgba(111,19,32,.06);">
        <span style="width:6px;height:6px;border-radius:50%;background:#6F1320;box-shadow:0 0 10px #6F1320;"></span>
        <span style="font-size:11.5px;letter-spacing:.34em;color:#A81E2E;font-weight:600;">PRIVATE CAPITAL &amp; BUSINESS SOLUTIONS</span>
      </div>
      <h1 data-reveal style="font-family:'Bodoni Moda',serif;font-weight:600;font-size:clamp(38px,6.6vw,78px);line-height:1.05;letter-spacing:-.01em;color:#F6F2E9;max-width:20ch;">Private Capital Connections for <span style="background:linear-gradient(120deg,#A81E2E,#6F1320,#A81E2E);background-size:200% auto;-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;animation:sheen 7s ease-in-out infinite;font-style:italic;">Business Owners, Real Estate Investors &amp; Entrepreneurs</span></h1>
      <p data-reveal style="max-width:62ch;font-size:clamp(16px,1.7vw,19px);line-height:1.7;color:#AEB4BF;font-weight:300;">Enigma Enterprises is a consulting and referral firm. We connect business owners, real estate investors, entrepreneurs and brokers with lenders, private capital partners and the right financing solutions — with strategy and compliance guiding every introduction.</p>
      <div data-reveal data-hero-actions style="display:flex;gap:14px;margin-top:8px;flex-wrap:wrap;justify-content:center;">
        <a href="#apply" class="btn-gold" data-magnetic style="font-size:14px;padding:17px 36px;">Submit a Funding Request</a>
        <a href="#apply" class="btn-outline" data-magnetic style="font-size:14px;padding:17px 32px;">Request a Consultation</a>
      </div>
      <div data-reveal style="display:flex;gap:10px 24px;flex-wrap:wrap;justify-content:center;margin-top:6px;">
        {['No cost · No obligation', 'Licensed lender network', '100% confidential'].map((t) => (
          <span style="display:inline-flex;align-items:center;gap:8px;font-size:12.5px;letter-spacing:.03em;color:#8B919C;">
            <span style="width:5px;height:5px;border-radius:50%;background:var(--gold-2);box-shadow:0 0 8px rgba(168,30,46,.6);flex:none;"></span>{t}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== COSTURA DORADA (hero → números) ===== -->
  <div class="seam" aria-hidden="true"></div>

  <!-- ===== STATS / TRUST NUMBERS (valores fijos, nunca 0) ===== -->
  <section class="bg-section" style="border-top:1px solid rgba(111,19,32,.12);border-bottom:1px solid rgba(111,19,32,.12);padding:clamp(48px,7vw,76px) clamp(18px,4vw,48px);">
    <div class="bg-layer"><img src="/img/1554260570-9140fd3b7614.jpg" alt="" aria-hidden="true" loading="lazy" decoding="async" /></div>
    <div class="bg-veil" style="background:linear-gradient(180deg,rgba(10,13,18,.84),rgba(12,16,23,.88));"></div>
    <div data-reveal style="width:min(1180px,100%);margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:24px;text-align:center;">
      {stats.map(([value, label], i) => (
        <div style={`display:flex;flex-direction:column;gap:10px;padding:14px;${i > 0 ? 'border-left:1px solid rgba(111,19,32,.14);' : ''}`}>
          <span style="font-family:'Bodoni Moda',serif;font-weight:600;font-size:clamp(40px,5vw,58px);color:#CE5567;line-height:1;">{value}</span>
          <span style="font-size:12px;letter-spacing:.16em;color:#969CA8;text-transform:uppercase;">{label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== MARQUEE / TRUST STRIP ===== -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      {['Private Capital', 'Credit Repair', 'Business Credit', 'Real Estate Funding', 'Merchant Services', 'Hard Money', 'Trust Education', 'Personal Funding'].concat(['Private Capital', 'Credit Repair', 'Business Credit', 'Real Estate Funding', 'Merchant Services', 'Hard Money', 'Trust Education', 'Personal Funding']).map((w) => (
        <span class="marquee-item">{w}</span>
      ))}
    </div>
  </div>

  <!-- ===== WHAT WE DO ===== -->
  <section id="approach" style="padding:clamp(80px,11vw,140px) clamp(18px,4vw,48px);">
    <div data-split style="width:min(1180px,100%);margin:0 auto;display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(40px,6vw,80px);align-items:center;">
      <div data-reveal="left" style="display:flex;flex-direction:column;gap:26px;">
        <span class="eyebrow">WHAT WE DO</span>
        <h2 class="h2">A consulting partner, not a lender.</h2>
        <p style="font-size:16.5px;line-height:1.75;color:#AEB4BF;font-weight:300;">Enigma Enterprises operates as a referral and advisory firm. We do not issue loans or hold deposits. Instead, we study your situation, then match you with the private capital networks and licensed lenders best positioned to say yes — with strategy and compliance guiding every introduction.</p>
        <div style="display:flex;flex-direction:column;gap:18px;margin-top:4px;">
          {points.map(([t, d], i) => (
            <div style="display:flex;gap:16px;align-items:flex-start;">
              <span style="flex:none;margin-top:3px;width:30px;height:30px;border-radius:50%;border:1px solid rgba(111,19,32,.45);display:flex;align-items:center;justify-content:center;color:#A81E2E;font-family:'Bodoni Moda',serif;font-size:15px;">{i + 1}</span>
              <div><h4 style="margin:0 0 5px;font-size:16px;color:#F0ECE3;font-weight:600;font-family:var(--font-sans);">{t}</h4><p style="margin:0;font-size:14.5px;color:#9AA0AB;line-height:1.6;font-weight:300;">{d}</p></div>
            </div>
          ))}
        </div>
      </div>
      <div data-reveal="right" style="position:relative;">
        <div style="position:absolute;inset:-1px;border-radius:3px;background:linear-gradient(135deg,rgba(111,19,32,.5),rgba(111,19,32,0) 55%);"></div>
        <div style="position:relative;height:clamp(360px,46vw,520px);border-radius:3px;overflow:hidden;">
          <img src="/img/1521791136064-7986c2920216.jpg" alt="Two business professionals shaking hands to close a financing agreement" loading="lazy" decoding="async" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;animation:kenburns 24s ease-in-out infinite alternate;" />
          <div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(10,13,18,.12),rgba(10,13,18,.62));"></div>
          <div style="position:absolute;left:24px;bottom:22px;display:flex;align-items:center;gap:11px;">
            <span style="width:7px;height:7px;border-radius:50%;background:#6F1320;box-shadow:0 0 10px #6F1320;"></span>
            <span style="font-size:12.5px;letter-spacing:.16em;color:#E8E2D4;text-transform:uppercase;font-weight:600;">Relationships that close deals</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== COSTURA DORADA (how it works) ===== -->
  <div class="seam" aria-hidden="true"></div>

  <!-- ===== PARALLAX BANNER (statement cinematográfico) ===== -->
  <section class="bg-section" style="position:relative;min-height:clamp(360px,52vh,540px);display:flex;align-items:center;justify-content:center;text-align:center;padding:clamp(60px,9vw,110px) clamp(18px,4vw,48px);border-top:1px solid rgba(111,19,32,.12);border-bottom:1px solid rgba(111,19,32,.12);">
    <div class="bg-layer"><img data-parallax-img="0.24" src="/img/1554469384-e58fac16e23a.jpg" alt="" aria-hidden="true" loading="lazy" decoding="async" /></div>
    <div class="bg-veil" style="background:radial-gradient(120% 100% at 50% 50%,rgba(10,13,18,.55),rgba(8,11,16,.8)),linear-gradient(180deg,rgba(8,11,16,.7),rgba(8,11,16,.55) 50%,rgba(8,11,16,.7));"></div>
    <div data-reveal="zoom" style="width:min(880px,92%);display:flex;flex-direction:column;align-items:center;gap:22px;">
      <span style="font-size:11.5px;letter-spacing:.4em;color:var(--gold-2);font-weight:600;">STRATEGY · CAPITAL · TRUST</span>
      <p style="margin:0;font-family:'Bodoni Moda',serif;font-weight:500;font-style:italic;font-size:clamp(26px,4.2vw,50px);line-height:1.2;color:#F8F4EB;text-wrap:balance;">We don't just find capital — we position you to receive it, with the discretion and diligence serious money expects.</p>
      <a href="#apply" class="btn-gold" data-magnetic style="font-size:14px;padding:16px 34px;">Submit a Funding Request</a>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section id="process" class="bg-section" style="padding:clamp(72px,9vw,120px) clamp(18px,4vw,48px);">
    <div class="bg-layer"><img src="/img/1507679799987-c73779587ccf.jpg" alt="" aria-hidden="true" loading="lazy" decoding="async" /></div>
    <div class="bg-veil" style="background:linear-gradient(180deg,rgba(8,11,16,.92),rgba(10,13,18,.94));"></div>
    <div style="width:min(1180px,100%);margin:0 auto;">
      <div data-reveal style="text-align:center;display:flex;flex-direction:column;gap:14px;align-items:center;margin-bottom:48px;">
        <span class="eyebrow">HOW IT WORKS</span>
        <h2 class="h2" style="max-width:20ch;">From application to funding in three steps.</h2>
        <p class="lead" style="max-width:56ch;">A simple, transparent process built around your goals — with no obligation at any stage.</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:22px;">
        {steps.map(([n, t, d], i) => (
          <div data-reveal class="lift" style={`position:relative;border:1px solid var(--line);border-radius:3px;padding:38px 32px;background:rgba(17,21,28,.5);display:flex;flex-direction:column;gap:14px;transition-delay:${(i * 0.1).toFixed(2)}s;`}>
            <span style="font-family:'Bodoni Moda',serif;font-size:44px;line-height:1;color:var(--gold-2);">{n}</span>
            <h3 style="font-family:'Bodoni Moda',serif;font-weight:600;font-size:23px;color:#F2EEE6;">{t}</h3>
            <p style="margin:0;font-size:14.5px;line-height:1.65;color:#9AA0AB;font-weight:300;">{d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CTA BAND — Submit a Funding Request ===== -->
  <section style="padding:clamp(20px,4vw,44px) clamp(18px,4vw,48px);">
    <div data-reveal="zoom" style="width:min(1100px,100%);margin:0 auto;border:1px solid rgba(111,19,32,.3);border-radius:3px;padding:clamp(32px,4vw,52px) clamp(28px,5vw,60px);background:radial-gradient(120% 160% at 0% 0%,rgba(168,30,46,.16),rgba(10,13,18,0) 60%),linear-gradient(180deg,rgba(17,21,28,.7),rgba(10,13,18,.8));display:flex;gap:26px;align-items:center;justify-content:space-between;flex-wrap:wrap;">
      <div style="display:flex;flex-direction:column;gap:8px;min-width:min(100%,340px);flex:1;">
        <h2 style="font-family:'Bodoni Moda',serif;font-weight:600;font-size:clamp(26px,3.4vw,40px);line-height:1.1;color:#F6F2E9;">Ready to move? Submit your deal.</h2>
        <p style="margin:0;font-size:15.5px;line-height:1.6;color:#AEB4BF;font-weight:300;">Owners and brokers welcome. Get your funding request reviewed within one business day.</p>
      </div>
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <a href="#apply" class="btn-gold" data-magnetic style="font-size:14px;padding:16px 32px;">Submit a Funding Request</a>
        <a href="https://wa.me/14134550488" target="_blank" rel="noopener" class="btn-wa" data-magnetic style="font-size:14px;padding:16px 26px;">WhatsApp</a>
      </div>
    </div>
  </section>

  <!-- ===== COSTURA DORADA (financing) ===== -->
  <div class="seam" aria-hidden="true"></div>

  <!-- ===== FINANCING (TABS) — Personal & Business / Real Estate / Products ===== -->
  <section id="services" class="bg-section clip-top sweep" style="padding:clamp(96px,12vw,150px) clamp(18px,4vw,48px) clamp(72px,9vw,120px);">
    <div class="bg-layer"><img src="/img/1620714223084-8fcacc6dfd8d.jpg" alt="" aria-hidden="true" loading="lazy" decoding="async" /></div>
    <div class="bg-veil" style="background:linear-gradient(180deg,rgba(8,11,16,.93),rgba(12,16,23,.9) 50%,rgba(8,11,16,.93));"></div>
    <div style="width:min(1180px,100%);margin:0 auto;">
      <div data-reveal style="text-align:center;display:flex;flex-direction:column;gap:16px;align-items:center;margin-bottom:46px;">
        <span class="eyebrow">FINANCING SOLUTIONS</span>
        <h2 class="h2" style="max-width:18ch;">Capital for every stage of your ambition.</h2>
        <p class="lead" style="max-width:60ch;">Explore our solutions by category. Each one connects you to vetted lenders within our network.</p>
      </div>
      <div data-tabrow style="display:flex;justify-content:center;gap:8px;margin-bottom:44px;border-bottom:1px solid rgba(111,19,32,.14);flex-wrap:wrap;">
        {['Personal & Business', 'Real Estate', 'Products & Requirements'].map((t, i) => (
          <button data-tab-btn={i} style="position:relative;background:transparent;border:none;cursor:pointer;padding:16px 22px;font-size:14px;font-weight:600;letter-spacing:.04em;color:#8B919C;transition:color .3s;">
            {t}<span data-tab-underline style="position:absolute;left:14px;right:14px;bottom:-1px;height:2px;background:linear-gradient(90deg,#A81E2E,#6F1320);display:none;"></span>
          </button>
        ))}
      </div>

      <div data-tab-panel="0" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(270px,1fr));gap:22px;">
        {financing.map((c, i) => (
          <div class="card" data-reveal data-spot style={`transition-delay:${(i * 0.08).toFixed(2)}s`}>
            <div class="card-img"><img src={c.img} alt={c.name} loading="lazy" decoding="async" /></div>
            <div class="card-body">
              <span class="card-rule"></span>
              <h3 class="card-title">{c.name}</h3>
              <p class="card-desc">{c.desc}</p>
