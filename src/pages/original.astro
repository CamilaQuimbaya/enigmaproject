---
// COPIA DE COMPARACIÓN: las secciones tal como estaban originalmente (dorado,
// sin fondos/animaciones/diagonales añadidas ni schedule/whatsapp).
// Visítala en /original — no afecta a la página real (/).
import Layout from '../layouts/Layout.astro';
import { financing, realEstate, products, exclusive } from '../data/services';

const LOGO = '/enigma-logo-gold.png';
const points = [
  ['Consulting & Referral Model', 'We connect you to the right source of capital — no balance sheet of our own to protect.'],
  ['A Personalized Approach', 'Every introduction is tailored to your goals, your timeline, and your numbers.'],
  ['Compliance First', 'We work only with licensed lenders, and final decisions always rest with them.'],
];
const stats = [
  ['100', '$', 'M+', 'Capital Range Accessed'],
  ['500', '', '+', 'Businesses Connected'],
  ['15', '', '+', 'Years of Experience'],
  ['50', '', '', 'States Served'],
];
---

<Layout>
  <div style="max-width:900px;margin:90px auto 0;padding:14px 20px;text-align:center;color:#E4CD8E;font-size:13px;letter-spacing:.1em;border:1px solid rgba(199,162,75,.3);border-radius:4px;">
    VERSIÓN ORIGINAL (solo para comparar) — <a href="/" style="color:#E4CD8E;text-decoration:underline;">ver versión actual →</a>
  </div>

  <!-- ===== HERO ===== -->
  <section id="top" style="position:relative;min-height:90vh;display:flex;align-items:center;overflow:hidden;padding:70px clamp(18px,4vw,48px) 90px;">
    <div style="position:absolute;inset:0;overflow:hidden;pointer-events:none;">
      <img src="/img/1486406146926-c627a92ad1ab.jpg" alt="" aria-hidden="true" decoding="async" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.58;" />
      <div style="position:absolute;inset:0;background:radial-gradient(120% 90% at 50% 40%,rgba(10,13,18,.5),rgba(10,13,18,.78)),linear-gradient(180deg,rgba(10,13,18,.55),rgba(10,13,18,.7) 70%,#0A0D12);"></div>
    </div>
    <div style="position:relative;width:min(1180px,100%);margin:0 auto;display:flex;flex-direction:column;align-items:center;text-align:center;gap:30px;">
      <img src={LOGO} alt="Enigma" style="width:clamp(120px,14vw,160px);height:auto;object-fit:contain;" />
      <div style="display:inline-flex;align-items:center;gap:14px;padding:9px 20px;border:1px solid rgba(199,162,75,.34);border-radius:40px;background:rgba(199,162,75,.06);">
        <span style="width:6px;height:6px;border-radius:50%;background:#C7A24B;box-shadow:0 0 10px #C7A24B;"></span>
        <span style="font-size:11.5px;letter-spacing:.34em;color:#E4CD8E;font-weight:600;">PRIVATE CAPITAL &amp; BUSINESS SOLUTIONS</span>
      </div>
      <h1 style="font-family:'Bodoni Moda',serif;font-weight:600;font-size:clamp(40px,7.4vw,86px);line-height:1.04;letter-spacing:-.01em;color:#F6F2E9;max-width:16ch;">Connecting You With the Right <span style="color:#E4CD8E;font-style:italic;">Financial Solutions</span></h1>
      <p style="max-width:62ch;font-size:clamp(16px,1.7vw,19px);line-height:1.7;color:#AEB4BF;font-weight:300;">We are a financial consulting and referral firm built for entrepreneurs and business owners. Through our network of private capital and licensed lenders, we open doors to the funding and strategy your next move demands.</p>
      <div style="display:flex;gap:16px;margin-top:8px;">
        <a href="#contact" class="btn-gold" style="font-size:14px;padding:17px 38px;">Apply Now</a>
        <a href="#contact" class="btn-outline" style="font-size:14px;padding:17px 38px;">Request a Consultation</a>
      </div>
    </div>
  </section>

  <!-- ===== STATS ===== -->
  <section style="border-top:1px solid rgba(199,162,75,.12);border-bottom:1px solid rgba(199,162,75,.12);background:linear-gradient(180deg,rgba(12,16,23,.66),rgba(10,13,18,.66));padding:clamp(48px,7vw,76px) clamp(18px,4vw,48px);">
    <div style="width:min(1180px,100%);margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:24px;text-align:center;">
      {stats.map(([count, pre, suf, label], i) => (
        <div style={`display:flex;flex-direction:column;gap:10px;padding:14px;${i > 0 ? 'border-left:1px solid rgba(199,162,75,.12);' : ''}`}>
          <span style="font-family:'Bodoni Moda',serif;font-weight:600;font-size:clamp(40px,5vw,58px);color:#E4CD8E;line-height:1;">{pre}{count}{suf}</span>
          <span style="font-size:12px;letter-spacing:.16em;color:#969CA8;text-transform:uppercase;">{label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== WHAT WE DO ===== -->
  <section id="services" style="padding:clamp(80px,11vw,140px) clamp(18px,4vw,48px);">
    <div style="width:min(1180px,100%);margin:0 auto;display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(40px,6vw,80px);align-items:center;">
      <div style="display:flex;flex-direction:column;gap:26px;">
        <span class="eyebrow">WHAT WE DO</span>
        <h2 class="h2">A consulting partner, not a lender.</h2>
        <p style="font-size:16.5px;line-height:1.75;color:#AEB4BF;font-weight:300;">Enigma Enterprises operates as a referral and advisory firm. We do not issue loans or hold deposits. Instead, we study your situation, then match you with the private capital networks and licensed lenders best positioned to say yes — with strategy and compliance guiding every introduction.</p>
        <div style="display:flex;flex-direction:column;gap:18px;margin-top:4px;">
          {points.map(([t, d], i) => (
            <div style="display:flex;gap:16px;align-items:flex-start;">
              <span style="flex:none;margin-top:3px;width:30px;height:30px;border-radius:50%;border:1px solid rgba(199,162,75,.45);display:flex;align-items:center;justify-content:center;color:#E4CD8E;font-family:'Bodoni Moda',serif;font-size:15px;">{i + 1}</span>
              <div><h4 style="margin:0 0 5px;font-size:16px;color:#F0ECE3;font-weight:600;font-family:var(--font-sans);">{t}</h4><p style="margin:0;font-size:14.5px;color:#9AA0AB;line-height:1.6;font-weight:300;">{d}</p></div>
            </div>
          ))}
        </div>
      </div>
      <div style="position:relative;">
        <div style="position:absolute;inset:-1px;border-radius:4px;background:linear-gradient(135deg,rgba(199,162,75,.5),rgba(199,162,75,0) 55%);"></div>
        <div style="position:relative;height:clamp(360px,46vw,520px);border-radius:4px;overflow:hidden;">
          <img src="/img/1521791136064-7986c2920216.jpg" alt="Handshake" loading="lazy" decoding="async" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" />
          <div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(10,13,18,.12),rgba(10,13,18,.62));"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FINANCING (TABS) ===== -->
  <section id="financing" style="padding:clamp(72px,9vw,120px) clamp(18px,4vw,48px);background:linear-gradient(180deg,rgba(10,13,18,.62),rgba(12,16,23,.6) 50%,rgba(10,13,18,.62));">
    <div style="width:min(1180px,100%);margin:0 auto;">
      <div style="text-align:center;display:flex;flex-direction:column;gap:16px;align-items:center;margin-bottom:46px;">
        <span class="eyebrow">FINANCING SOLUTIONS</span>
        <h2 class="h2" style="max-width:18ch;">Capital for every stage of your ambition.</h2>
        <p class="lead" style="max-width:60ch;">Explore our solutions by category. Each one connects you to vetted lenders within our network.</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(270px,1fr));gap:22px;margin-bottom:22px;">
        {financing.map((c) => (
          <div class="card">
            <div class="card-img"><img src={c.img} alt={c.name} loading="lazy" decoding="async" /></div>
            <div class="card-body">
              <span class="card-rule"></span>
              <h3 class="card-title">{c.name}</h3>
              <p class="card-desc">{c.desc}</p>
            </div>
          </div>
        ))}
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(270px,1fr));gap:22px;margin-bottom:22px;">
        {realEstate.map((c) => (
          <div class="card">
            <div class="card-img"><img src={c.img} alt={c.name} loading="lazy" decoding="async" /></div>
            <div class="card-body">
              <span class="card-rule"></span>
              <h3 class="card-title">{c.name}</h3>
              <p class="card-desc">{c.desc}</p>
            </div>
          </div>
        ))}
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:22px;">
        {products.map((p) => (
          <div class="card" style="padding:32px 28px;gap:14px;">
            <h3 class="card-title">{p.name}</h3>
            <p class="card-desc" style="font-size:14px;">{p.desc}</p>
            <div style="display:flex;flex-direction:column;margin-top:2px;">
              {p.specs.map((s) => (
                <div style="display:flex;justify-content:space-between;align-items:baseline;gap:14px;padding:9px 0;border-top:1px solid rgba(255,255,255,.06);">
                  <span style="font-size:12px;letter-spacing:.06em;text-transform:uppercase;color:#888E99;">{s.k}</span>
                  <span style="font-size:13.5px;font-weight:600;color:#E4CD8E;text-align:right;">{s.v}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== UK SYNDICATE ===== -->
  <section id="realestate" style="padding:clamp(72px,9vw,120px) clamp(18px,4vw,48px);">
    <div style="width:min(1180px,100%);margin:0 auto;position:relative;border-radius:5px;overflow:hidden;border:1px solid rgba(199,162,75,.25);">
      <div style="position:absolute;inset:0;overflow:hidden;">
        <img src="/img/1480714378408-67cf0d13bc1b.jpg" alt="Skyline" loading="lazy" decoding="async" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" />
      </div>
      <div style="position:absolute;inset:0;background:linear-gradient(110deg,rgba(8,11,16,.94) 32%,rgba(8,11,16,.6) 70%,rgba(8,11,16,.4)),radial-gradient(80% 120% at 110% 50%,rgba(199,162,75,.18),rgba(8,11,16,0) 60%);"></div>
      <div style="position:relative;padding:clamp(44px,6vw,80px) clamp(28px,5vw,72px);display:flex;flex-direction:column;gap:20px;max-width:680px;">
        <span style="font-size:11px;letter-spacing:.34em;color:#E4CD8E;font-weight:600;">FLAGSHIP PROGRAM</span>
        <h2 style="font-family:'Bodoni Moda',serif;font-weight:600;font-size:clamp(34px,5vw,60px);line-height:1.05;color:#F8F4EB;">UK Base Syndicate Program</h2>
        <div style="display:flex;align-items:baseline;gap:14px;flex-wrap:wrap;">
          <span style="font-family:'Bodoni Moda',serif;font-size:clamp(30px,4vw,46px);font-weight:600;color:#E4CD8E;">$3M – $100M</span>
          <span style="font-size:13px;letter-spacing:.1em;color:#AEB4BF;text-transform:uppercase;">institutional capital syndication</span>
        </div>
        <p style="font-size:16px;line-height:1.7;color:#C4C9D1;font-weight:300;max-width:54ch;">Our most exclusive offering — structured syndicated capital for large-scale acquisitions, development, and commercial real estate ventures, sourced through an international network of private investors and institutions.</p>
        <a href="#contact" class="btn-gold" style="align-self:flex-start;margin-top:6px;font-size:13.5px;padding:15px 34px;">Inquire About Syndication</a>
      </div>
    </div>
  </section>

  <!-- ===== EXCLUSIVE ===== -->
  <section style="padding:clamp(40px,5vw,70px) clamp(18px,4vw,48px) clamp(72px,9vw,120px);">
    <div style="width:min(1180px,100%);margin:0 auto;">
      <div style="display:flex;flex-direction:column;gap:14px;margin-bottom:42px;">
        <span class="eyebrow">EXCLUSIVE SERVICES</span>
        <h2 class="h2">Beyond funding — building the foundation.</h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:1px;background:rgba(199,162,75,.14);border:1px solid rgba(199,162,75,.14);border-radius:3px;overflow:hidden;">
        {exclusive.map((c) => (
          <div style="background:#0B0F15;padding:36px 30px;display:flex;flex-direction:column;gap:12px;min-height:200px;">
            <span style="font-family:'Bodoni Moda',serif;font-size:20px;color:#C7A24B;">0{c.n}</span>
            <h3 style="font-family:'Bodoni Moda',serif;font-weight:600;font-size:22px;color:#F2EEE6;line-height:1.15;">{c.name}</h3>
            <p style="margin:0;font-size:14px;line-height:1.6;color:#9AA0AB;font-weight:300;">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== MERCHANT SERVICES ===== -->
  <section style="padding:clamp(60px,7vw,96px) clamp(18px,4vw,48px);background:linear-gradient(180deg,rgba(10,13,18,.62),rgba(12,16,23,.6),rgba(10,13,18,.62));">
    <div style="width:min(1100px,100%);margin:0 auto;display:grid;grid-template-columns:1fr auto;gap:36px;align-items:center;border:1px solid rgba(199,162,75,.18);border-radius:4px;padding:clamp(34px,4vw,56px);background:rgba(255,255,255,.025);">
      <div style="display:flex;flex-direction:column;gap:14px;">
        <span class="eyebrow">MERCHANT SERVICES</span>
        <h2 style="font-family:'Bodoni Moda',serif;font-weight:600;font-size:clamp(28px,3.6vw,42px);line-height:1.12;color:#F4F0E8;">Free credit card processing review.</h2>
        <p style="font-size:15.5px;line-height:1.7;color:#AEB4BF;font-weight:300;max-width:54ch;">Most businesses overpay on card processing fees. We'll audit your current statements at no cost and show you exactly where margin is leaking — and how to recover it.</p>
      </div>
      <a href="#contact" class="btn-outline" style="flex:none;text-align:center;font-size:14px;padding:16px 32px;">Get a Free Fee Review</a>
    </div>
  </section>

  <!-- ===== EDUCATION ===== -->
  <section id="education" style="padding:clamp(72px,9vw,120px) clamp(18px,4vw,48px);">
    <div style="width:min(1180px,100%);margin:0 auto;">
      <div style="text-align:center;display:flex;flex-direction:column;gap:14px;align-items:center;margin-bottom:44px;">
        <span class="eyebrow">EDUCATION</span>
        <h2 class="h2" style="max-width:20ch;">Knowledge is the first form of capital.</h2>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;">
        <div style="position:relative;overflow:hidden;border:1px solid rgba(199,162,75,.2);border-radius:4px;padding:clamp(34px,4vw,52px);background:linear-gradient(155deg,rgba(12,16,23,.72),rgba(8,11,16,.93)),url('/img/1450101499163-c8848c66ca85.jpg') center/cover;display:flex;flex-direction:column;gap:16px;">
          <span style="font-size:11px;letter-spacing:.28em;color:#C7A24B;font-weight:600;">SIGNATURE PROGRAM</span>
          <h3 style="font-family:'Bodoni Moda',serif;font-weight:600;font-size:clamp(26px,3vw,36px);color:#F4F0E8;line-height:1.1;">Wealthy Trustee Program</h3>
          <p style="font-size:15px;line-height:1.7;color:#AEB4BF;font-weight:300;">A deep education in trusts, asset protection, and generational wealth structures — designed to help you hold and transfer what you build with intention and discretion.</p>
        </div>
        <div style="position:relative;overflow:hidden;border:1px solid rgba(199,162,75,.2);border-radius:4px;padding:clamp(34px,4vw,52px);background:linear-gradient(155deg,rgba(12,16,23,.72),rgba(8,11,16,.93)),url('/img/1600880292203-757bb62b4baf.jpg') center/cover;display:flex;flex-direction:column;gap:16px;">
          <span style="font-size:11px;letter-spacing:.28em;color:#C7A24B;font-weight:600;">FREE WEBINAR</span>
          <h3 style="font-family:'Bodoni Moda',serif;font-weight:600;font-size:clamp(26px,3vw,36px);color:#F4F0E8;line-height:1.1;">Business Acquisition Webinar</h3>
          <p style="font-size:15px;line-height:1.7;color:#AEB4BF;font-weight:300;">Learn how to buy existing, cash-flowing businesses — sourcing, valuation, deal structure, and the funding that makes acquisitions possible. Live, free, and no obligation.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CINEMATIC DIVIDER ===== -->
  <section style="position:relative;height:clamp(420px,60vh,620px);overflow:hidden;display:flex;align-items:center;justify-content:center;text-align:center;">
    <img src="/img/1449824913935-59a10b8d2000.jpg" alt="City at night" loading="lazy" decoding="async" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" />
    <div style="position:absolute;inset:0;background:radial-gradient(120% 100% at 50% 50%,rgba(10,13,18,.55),rgba(10,13,18,.82)),linear-gradient(180deg,#0A0D12,rgba(10,13,18,0) 18%,rgba(10,13,18,0) 82%,#0A0D12);"></div>
    <div style="position:relative;width:min(880px,90%);display:flex;flex-direction:column;align-items:center;gap:22px;padding:0 20px;">
      <span style="font-size:11.5px;letter-spacing:.4em;color:#E4CD8E;font-weight:600;">THE ENIGMA STANDARD</span>
      <p style="margin:0;font-family:'Bodoni Moda',serif;font-weight:500;font-style:italic;font-size:clamp(26px,4.4vw,52px);line-height:1.22;color:#F8F4EB;">"Capital is everywhere. The difference is knowing exactly where it belongs — and who to trust to place it."</p>
      <span style="width:54px;height:2px;background:linear-gradient(90deg,#E4CD8E,#C7A24B);"></span>
    </div>
  </section>

  <!-- ===== PARTNER ===== -->
  <section style="padding:clamp(60px,7vw,100px) clamp(18px,4vw,48px);">
    <div style="width:min(1100px,100%);margin:0 auto;text-align:center;border:1px solid rgba(199,162,75,.2);border-radius:5px;padding:clamp(44px,6vw,76px) clamp(28px,5vw,64px);background:radial-gradient(120% 140% at 50% 0%,rgba(199,162,75,.14),rgba(10,13,18,0) 55%),linear-gradient(180deg,rgba(8,11,16,.82),rgba(8,11,16,.93)),url('/img/1556761175-b413da4baf72.jpg') center/cover;display:flex;flex-direction:column;align-items:center;gap:20px;">
      <span class="eyebrow">BECOME A PARTNER</span>
      <h2 class="h2" style="max-width:18ch;">Start Your Own Funding Agency.</h2>
      <p class="lead" style="max-width:58ch;">Join our affiliate program and build a business around the capital network we've spent years developing. We provide the lenders, the products, and the playbook — you bring the relationships.</p>
      <a href="#contact" class="btn-gold" style="margin-top:6px;font-size:14px;padding:16px 38px;">Become an Affiliate</a>
    </div>
  </section>

  <!-- ===== CONTACT ===== -->
  <section id="contact" style="position:relative;overflow:hidden;padding:clamp(80px,11vw,150px) clamp(18px,4vw,48px);background:linear-gradient(180deg,rgba(10,13,18,.6),rgba(12,17,24,.66));border-top:1px solid rgba(199,162,75,.12);">
    <div style="position:relative;width:min(680px,100%);margin:0 auto;text-align:center;display:flex;flex-direction:column;align-items:center;gap:22px;">
      <span class="eyebrow">REQUEST A CONSULTATION</span>
      <h2 style="font-family:'Bodoni Moda',serif;font-weight:600;font-size:clamp(34px,5vw,62px);line-height:1.05;color:#F8F4EB;">Let's find your right solution.</h2>
      <p class="lead" style="max-width:48ch;font-size:16.5px;">Share your email and our team will reach out to understand your goals — no cost, no obligation.</p>
      <form style="margin-top:8px;display:flex;gap:12px;width:100%;max-width:520px;flex-wrap:wrap;justify-content:center;">
        <input type="email" required placeholder="Your email address" aria-label="Your email address" class="field" style="flex:1;min-width:220px;" />
        <button type="submit" class="btn-gold" style="flex:none;font-size:14px;padding:16px 34px;">Request Consultation</button>
      </form>
    </div>
  </section>
</Layout>
